---
import "../styles/global.css";
import "../styles/animations.css";
import Loader from "../components/global/Loader.astro";
---

<!doctype html>
<html lang="it">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Davide La Marca</title>
		<script>
			if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark')
			}
		</script>
	</head>
	<body class="bg-white dark:bg-gray-900">
		<Loader />
		<slot />	
	</body>
</html>

<script is:inline src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
<script src="../scripts/pageLoader.js"></script>
<script src="../scripts/mobileMenu.js"></script>
<script src="../scripts/darkModeToggle.js"></script>
<script src="../scripts/navbarScroll.js"></script>